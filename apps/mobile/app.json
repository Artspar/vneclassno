{
  "expo": {
    "name": "VneClassno",
    "slug": "vneclassno-mobile",
    "scheme": "vneclassno",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vneclassno.mobile"
    },
    "android": {
      "package": "com.vneclassno.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
