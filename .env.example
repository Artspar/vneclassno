# Shared
NODE_ENV=development

# Runtime mode
APP_STORE=prisma
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://127.0.0.1:3001,http://127.0.0.1:3002

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vneclassno

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
AUTH_ALLOW_UNSAFE_TELEGRAM_ID=true
AUTH_ALLOW_LEGACY_OTP=true
OTP_EXPOSE_CODE=true
OTP_TTL_SEC=300
OTP_MAX_ATTEMPTS=5

# Telegram
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_BOT_USERNAME=vneclassno_bot
TELEGRAM_MINIAPP_URL=http://localhost:3002

# Demo role mapping (optional)
DEMO_COACH_PHONES=+79990000002
DEMO_SECTION_ADMIN_PHONES=+79990000003
DEMO_COACH_TELEGRAM_IDS=1001
DEMO_SECTION_ADMIN_TELEGRAM_IDS=1002
DEMO_COACH_SECTION_ID=section-a
DEMO_SECTION_ADMIN_SECTION_ID=section-b

# Frontend URL
PWA_BASE_URL=http://localhost:3001

# Payments
SBP_WEBHOOK_SECRET=change_me
